# ============================================\n# ROOT - .gitignore (MERN Stack POS)\n# ============================================\n\n# ---- IDE & Editor ----\n.vscode/\n.idea/\n*.sublime-project\n*.sublime-workspace\n*.swp\n*.swo\n\n# ---- OS Files ----\n.DS_Store\nThumbs.db\n\n# ---- Environment ----\n.env\n.env.local\n.env.*.local\n\n# ---- Temp & Cache ----\n.cache/\ntmp/\ntemp/\n*.log\n\n# ---- Dependencies (if node_modules at root) ----\nnode_modules/\npackage-lock.json\nyarn.lock\n\n# ---- Build Outputs ----\n/dist\n/build\n\n# ---- Keep frontend and backend gitignores ----\n# See frontend/.gitignore and backend/.gitignore for specific rules\n