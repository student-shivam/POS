# ============================================
# BACKEND - .gitignore
# ============================================

# ---- Dependencies ----
node_modules/
package-lock.json
yarn.lock

# ---- Environment Variables ----
.env
.env.local
.env.development
.env.production
.env.test

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log

# ---- OS & IDE ----
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---- Build & Temp ----
/dist
/build
.cache/
tmp/
temp/

# ---- Testing & Coverage ----
/coverage
.nyc_output/

# ---- Database ----
*.db
*.sqlite
*.sqlite3

# ---- Upload Directories ----
/uploads/
/temp/
/public/uploads/

# ---- IDE Generated Files ----
.eslintcache
.prettierignore
