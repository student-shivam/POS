# ============================================
# FRONTEND - .gitignore
# ============================================

# ---- Dependencies ----
node_modules/
/.pnp
.pnp.js
package-lock.json
yarn.lock

# ---- Environment Variables ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Build Output ----
/build
/dist
.next/

# ---- Testing & Coverage ----
/coverage
.nyc_output/

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ---- OS & IDE ----
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---- Build Logs ----
build_log.txt
